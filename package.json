{
  "name": "@countertop/n8n-nodes-countertop-studio",
  "version": "1.0.0-alpha.7",
  "description": "Official Countertop Studio integration nodes for n8n",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "copyfiles -u 1 \"src/nodes/**/*.svg\" dist",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-nodes-countertop-studio",
    "countertop-studio",
    "countertop",
    "countertopstudio",
    "countertop-studio-api",
    "countertop-studio-n8n"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/countertop-software/studio-n8n-nodes.git"
  },
  "author": "Countertop GmbH",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "ssh2": "^1.17.0",
    "n8n-workflow": "^2.10.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.33",
    "@types/ssh2": "^1.15.5",
    "copyfiles": "^2.4.1",
    "nock": "^14.0.11",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/CountertopSendDeal/CountertopStudioSendDeal.node.js",
      "dist/nodes/CountertopNormalizeDeal/CountertopStudioNormalizeDeal.node.js",
      "dist/nodes/CountertopValidateDeal/CountertopStudioValidateDeal.node.js"
    ],
    "credentials": [
      "dist/credentials/CountertopStudioApi.credentials.js"
    ]
  }
}
